# CIO Prototype - Environment Variables Template
# Copy this file to .env and fill in your actual keys.

# Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Optional fallback)
GROQ_API_KEY=your_groq_api_key_here

# Google Sheets Spreadsheet ID
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Sheets Service Account Key Path (Relative to root or absolute)
GOOGLE_SHEETS_KEY_PATH=secret/your-key-file.json

# LINE Messaging API Credentials
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here

# SEC EDGAR Compliance (User-Agent header required by SEC)
# Format: Name (email@example.com)
SEC_USER_AGENT=YourName (your-email@example.com)