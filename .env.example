# CIO Prototype - Environment Variables Template
# Copy this file to .env and fill in your actual keys.

# =============================================================================
# AI API Keys
# =============================================================================

# Gemini API Key (Required)
# Get from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API Key (Optional fallback)
# Get from: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# =============================================================================
# Data Source API Keys
# =============================================================================

# EDINET API Key (Optional, for Japanese stock reports)
# Get from: https://disclosure2dl.edinet-fsa.go.jp/
EDINET_API_KEY=your_edinet_subscription_key_here

# SEC EDGAR User-Agent (Required for US stocks)
# Format: YourName (your-email@example.com)
SEC_USER_AGENT=YourName (your-email@example.com)

# =============================================================================
# Google Sheets (Optional)
# =============================================================================
# Choose ONE of the following authentication methods:
#
# Method 1: JSON String (Recommended for cloud deployment)
# - Copy the entire service account JSON content here
# - Get from: Google Cloud Console > IAM & Admin > Service Accounts
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
#
# Method 2: File Path (Recommended for local development)
# - Place your service account JSON file in the secret/ directory
# - Reference the relative or absolute path
GOOGLE_SHEETS_KEY_PATH=secret/your-key-file.json

# Google Sheets Spreadsheet ID (Required if using Google Sheets output)
# - The ID is the long string in the URL: docs.google.com/spreadsheets/d/[THIS_ID]/edit
SPREADSHEET_ID=your_spreadsheet_id_here

# =============================================================================
# LINE Messaging API (Optional)
# =============================================================================
# Get from: LINE Developers Console > Your Channel > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_USER_ID=your_line_user_id_here
